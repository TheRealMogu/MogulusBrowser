{
  "name": "mogulus-browser",
  "version": "0.1.0",
  "description": "A personal, modern desktop browser built on Electron",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite --port 5174",
    "dev:main": "wait-on http://localhost:5174 && tsc -p tsconfig.main.json && electron .",
    "start": "npm run build && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "pack": "npm run build && electron-builder",
    "pack:dir": "npm run build && electron-builder --dir",
    "pack:linux": "npm run build && electron-builder --linux",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "browser",
    "electron",
    "desktop"
  ],
  "author": {
    "name": "TheRealMogu",
    "email": "lucamogu7@gmail.com"
  },
  "homepage": "https://github.com/therealmogu/mogulusbrowser",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.mogu.mogulus-browser",
    "productName": "Mogulus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons/512x512.png",
      "category": "Network"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/512x512.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/512x512.png"
    },
    "publish": {
      "provider": "github",
      "owner": "therealmogu",
      "repo": "mogulusbrowser"
    },
    "electronDownload": {
      "cache": "~/.cache/electron"
    },
    "npmRebuild": false
  }
}
